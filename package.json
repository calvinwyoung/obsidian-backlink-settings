{
  "name": "obsidian-backlink-settings",
  "version": "1.0.1",
  "description": "Obsidian plugin for configuring backlink display settings",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "check": "biome check .",
    "fix": "biome check --write .",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "esbuild": "^0.28.0",
    "obsidian": "latest",
    "obsidian-typings": "^5.18.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
