{
  "name": "obsidian-backlink-settings",
  "version": "1.0.0",
  "description": "Obsidian plugin for configuring backlink display settings",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "check": "biome check .",
    "fix": "biome check --write .",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "esbuild": "^0.25.0",
    "obsidian": "latest",
    "obsidian-typings": "^2.42.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
